{
  "name": "leetcode-prep",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && node --max-old-space-size=4096 node_modules/next/dist/bin/next build",
    "start": "next start",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:seed": "dotenv -e .env.local -- prisma generate && dotenv -e .env.local -- tsx scripts/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^3.0.3",
    "next": "14.2.0",
    "next-auth": "^5.0.0-beta.25",
    "nodemailer": "^7.0.13",
    "react": "^18",
    "react-dom": "^18"
  },
  "browserslist": [
    "chrome >= 93",
    "firefox >= 90",
    "safari >= 15",
    "edge >= 93",
    "not dead"
  ],
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.0",
    "postcss": "^8",
    "prisma": "^5.0.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
