# Upstash Redis (for rate limiting) — free tier at upstash.com
# 1. Create a Redis database at console.upstash.com
# 2. Copy "REST URL" and "REST Token" from the database page
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Gmail SMTP (for OTP emails)
# 1. Enable 2FA on your Google account
# 2. Go to myaccount.google.com/apppasswords
# 3. Create an App Password (select "Mail" + "Other")
# 4. Paste the 16-char password below (no spaces)
GMAIL_USER="you@gmail.com"
GMAIL_APP_PASSWORD=""
